        <mxCell id="v30_1" value="• Flutter Web build &amp; hosting" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="v30"><mxGeometry x="10" y="35" width="680" height="20" as="geometry" /></mxCell>
        <mxCell id="v30_2" value="• SEO-optimised panchangam pages for discoverability" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="v30"><mxGeometry x="10" y="55" width="680" height="20" as="geometry" /></mxCell>
        <mxCell id="v30_3" value="• Progressive Web App (installable, offline-capable)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="v30"><mxGeometry x="10" y="75" width="680" height="20" as="geometry" /></mxCell>

