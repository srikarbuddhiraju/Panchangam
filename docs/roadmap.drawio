        <mxCell id="v21_3" value="• iCloud sync for settings &amp; family data" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="v21"><mxGeometry x="10" y="75" width="680" height="20" as="geometry" /></mxCell>

        <!-- ═══ SECTION: WEB ═══ -->
        <mxCell id="sec_web" value="🌐  Web — broadest reach, final platform"
